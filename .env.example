# 默认会直接使用 Hugging Face 上的公开模型直链。
# 如需覆写，再填自己的模型 URL。
#
# Cloudflare Pages 单文件上限是 25 MiB，而公开的 migan.onnx 约 29.5 MiB，
# 所以默认不建议把模型打进 Pages 静态目录。
#
# ORT 的 wasm 默认从 jsDelivr 拉取；如果失败，Worker 会自动回退到 unpkg。

VITE_MODEL_URL=https://huggingface.co/andraniksargsyan/migan/resolve/main/migan_pipeline_v2.onnx
VITE_WASM_BASE_URL=https://cdn.jsdelivr.net/npm/onnxruntime-web@1.26.0/dist/
